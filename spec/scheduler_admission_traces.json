{
  "limitations": "These abstract fixtures prove transition selection and injected guard outcomes. Production conformance must compute identity, deadline, authority-snapshot, and projection guards from typed payloads and persisted context.",
  "cases": [
    {
      "id": "immediate-grant-and-release",
      "machine": "orbit_request",
      "steps": [
        {"event": "ADMISSION_GRANTED", "guard_results": {"admission_identity_current": true}, "expected_state": "HELD", "expected_effects": ["RecordLeaseGrant"]},
        {"event": "RELEASE", "guard_results": {"lease_authority_current": true}, "expected_state": "RELEASED", "expected_effects": ["RecordRelease"]}
      ]
    },
    {
      "id": "queued-promoted-and-renewed",
      "machine": "orbit_request",
      "steps": [
        {"event": "ADMISSION_QUEUED", "guard_results": {"admission_identity_current": true}, "expected_state": "PENDING", "expected_effects": ["RecordQueueEntry"]},
        {"event": "PROMOTION_GRANTED", "guard_results": {"promotion_identity_current": true}, "expected_state": "HELD", "expected_effects": ["RecordLeaseGrant"]},
        {"event": "RENEW", "guard_results": {"lease_authority_current": true}, "expected_state": "HELD", "expected_effects": ["RecordLeaseRenewal"]},
        {"event": "LEASE_EXPIRED", "guard_results": {"lease_timeout_due": true}, "expected_state": "EXPIRED", "expected_effects": ["RecordExpiration"]}
      ]
    },
    {
      "id": "policy-denial",
      "machine": "orbit_request",
      "steps": [
        {"event": "ADMISSION_DENIED", "guard_results": {"admission_identity_current": true}, "expected_state": "DENIED", "expected_effects": ["RecordDenial"]}
      ]
    },
    {
      "id": "queue-overload-rejection",
      "machine": "orbit_request",
      "steps": [
        {"event": "ADMISSION_REJECTED", "guard_results": {"admission_identity_current": true}, "expected_state": "REJECTED", "expected_effects": ["RecordOverload"]}
      ]
    },
    {
      "id": "cancel-before-decision",
      "machine": "orbit_request",
      "steps": [
        {"event": "CANCEL", "guard_results": {"wait_owner_current": true}, "expected_state": "CANCELLED", "expected_effects": ["RecordCancellation"]}
      ]
    },
    {
      "id": "blocked-then-cancelled",
      "machine": "orbit_request",
      "steps": [
        {"event": "ADMISSION_QUEUED", "guard_results": {"admission_identity_current": true}, "expected_state": "PENDING", "expected_effects": ["RecordQueueEntry"]},
        {"event": "PROMOTION_BLOCKED", "guard_results": {"promotion_identity_current": true}, "expected_state": "PENDING", "expected_effects": ["RecordQueueObservation"]},
        {"event": "CANCEL", "guard_results": {"wait_owner_current": true}, "expected_state": "CANCELLED", "expected_effects": ["RecordCancellation"]}
      ]
    },
    {
      "id": "wait-deadline",
      "machine": "orbit_request",
